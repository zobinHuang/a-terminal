#!/usr/bin/env bash
# [vibebox] vbox-mpv-ipc <socket> <command> [args...]
#
# Sends a JSON command to an mpv --input-ipc-server socket. Numbers are passed
# through unquoted, everything else is JSON-string-escaped. Failures are
# swallowed: this gets called from tmux status and shell hooks where stderr
# would corrupt the UI.

set -u

sock="${1:-}"
[ -n "$sock" ] || exit 0
shift

# build a JSON command array from positional args
args_json=""
sep=""
for a in "$@"; do
  if [[ "$a" =~ ^-?[0-9]+(\.[0-9]+)?$ ]]; then
    args_json+="${sep}${a}"
  else
    esc=${a//\\/\\\\}
    esc=${esc//\"/\\\"}
    args_json+="${sep}\"${esc}\""
  fi
  sep=","
done

# silently no-op if the socket isn't there (mpv not running, or just died)
[ -S "$sock" ] || exit 0

printf '{"command":[%s]}\n' "$args_json" \
  | socat -t 0.4 - "UNIX-CONNECT:${sock}" >/dev/null 2>&1 || true
