#!/usr/bin/env bash
# [vibebox] vbox-music — vibe radio dispatcher
#
# Subcommands:
#   start                 spawn the two mpv slot processes for this session
#   stop                  kill the mpv slot processes for this session
#   crossfade <url>       fade from active slot to inactive slot playing <url>
#   tick                  recompute focused pane's intensity → station, emit emoji
#   focus <pane_id>       called when pane focus changes
#   set-state <pane> <s>  s ∈ {idle,running,thinking}; called from shell/claude hooks
#   mute                  toggle global mute
#   bump <delta>          bump intensity by ±0.25 for 60s
#
# State lives in tmux user options: per-pane (@vibe-state, @vibe-intensity,
# @vibe-station, @vibe-bump-*) and per-session (@vibe-mpv-{a,b}-{sock,pid},
# @vibe-active-slot, @vibe-current-pane, @vibe-muted).
#
# All output to stderr is suppressed in production paths because this is
# called from tmux status-right and tmux hooks where stray text would corrupt
# the UI. Logging goes to ~/.cache/vibebox/music.log.

set -u

# ─── paths ───────────────────────────────────────────────────────────
VBOX_LOG_DIR="${HOME}/.cache/vibebox"
VBOX_LOG="${VBOX_LOG_DIR}/music.log"
VBOX_RUNTIME_DIR="${TMPDIR:-/tmp}/vbox-mpv-$(id -u)"
VBOX_CONFIG_DIR="${HOME}/.config/vibebox"
STATIONS_CONF="${VBOX_CONFIG_DIR}/stations.conf"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IPC_HELPER="${SCRIPT_DIR}/vbox-mpv-ipc"
[ -x "$IPC_HELPER" ] || IPC_HELPER="$(command -v vbox-mpv-ipc 2>/dev/null || echo "")"

mkdir -p "$VBOX_LOG_DIR" "$VBOX_RUNTIME_DIR"
chmod 700 "$VBOX_RUNTIME_DIR" 2>/dev/null || true

log() { printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$VBOX_LOG" 2>/dev/null || true; }

# ─── tmux option helpers (silent on missing options) ─────────────────
tmux_get()  { tmux show-options -t "$1" -v "$2" 2>/dev/null || true; }
tmux_set()  { tmux set-option  -t "$1"    "$2" "$3" >/dev/null 2>&1 || true; }
tmux_unset(){ tmux set-option  -t "$1" -u "$2"      >/dev/null 2>&1 || true; }
tmux_get_pane()   { tmux show-options -t "$1" -p -v "$2" 2>/dev/null || true; }
tmux_set_pane()   { tmux set-option  -t "$1" -p    "$2" "$3" >/dev/null 2>&1 || true; }
tmux_unset_pane() { tmux set-option  -t "$1" -p -u "$2"      >/dev/null 2>&1 || true; }
# window-scoped (-w). The target can be a pane id and tmux resolves to
# its window automatically.
tmux_get_win()    { tmux show-options -t "$1" -w -v "$2" 2>/dev/null || true; }
tmux_set_win()    { tmux set-option  -t "$1" -w    "$2" "$3" >/dev/null 2>&1 || true; }
tmux_unset_win()  { tmux set-option  -t "$1" -w -u "$2"      >/dev/null 2>&1 || true; }

# Resolve the tmux session id for a given target (pane id or session). Falls
# back to the currently-attached session when no target is supplied.
_session_of() {
  local target="${1:-}"
  if [ -n "$target" ]; then
    tmux display-message -p -t "$target" '#{session_id}' 2>/dev/null
  else
    tmux display-message -p '#{session_id}' 2>/dev/null
  fi
}

_tmux_pid() { tmux display-message -p '#{pid}' 2>/dev/null; }

# ─── platform-aware load sampling (hides Linux/macOS diff) ───────────
_ncpu() {
  case "$(uname)" in
    Darwin) sysctl -n hw.ncpu 2>/dev/null || echo 1 ;;
    *)      command -v nproc >/dev/null 2>&1 && nproc 2>/dev/null || echo 1 ;;
  esac
}

# Walk a process tree, emitting every descendant pid (including the root).
# Uses pgrep -P which is available on both Linux and macOS.
_descendants() {
  local pid="$1" child
  [ -n "$pid" ] || return 0
  printf '%s\n' "$pid"
  for child in $(pgrep -P "$pid" 2>/dev/null); do
    _descendants "$child"
  done
}

# Echoes "cpu_share mem_share" where each is normalised to [0.0, 1.0].
# cpu_share is summed across the whole process tree, divided by ncpu*100.
# Both ps implementations (BSD/macOS, procps/Linux) accept "%cpu=,%mem="
# to suppress headers, so the same call works on both.
_vbox_pane_load() {
  local pane_pid="$1"
  if [ -z "$pane_pid" ]; then
    echo "0 0"
    return
  fi
  local pids ncpu
  pids="$(_descendants "$pane_pid" | tr '\n' ' ')"
  if [ -z "${pids// /}" ]; then
    echo "0 0"
    return
  fi
  ncpu="$(_ncpu)"
  # shellcheck disable=SC2086  # intentional word splitting on pids
  ps -o %cpu=,%mem= -p $pids 2>/dev/null \
    | awk -v ncpu="$ncpu" 'BEGIN{c=0;m=0}
        {c+=$1; m+=$2}
        END{
          cs = c/(ncpu*100); if (cs<0) cs=0; if (cs>1) cs=1
          ms = m/100;        if (ms<0) ms=0; if (ms>1) ms=1
          printf "%.4f %.4f\n", cs, ms
        }'
}

# ─── stations.conf parsing ───────────────────────────────────────────
# Format: <min> <max> <url> <label words...>
# Returns "url<TAB>label" for the first range that matches.
_intensity_to_station() {
  local intensity="$1"
  [ -f "$STATIONS_CONF" ] || return 0
  awk -v t="$intensity" '
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
    {
      lo=$1; hi=$2; url=$3
      label=""
      for (i=4; i<=NF; i++) label = label (i==4?"":" ") $i
      if (t+0 >= lo+0 && t+0 <= hi+0) {
        printf "%s\t%s\n", url, label
        exit
      }
    }
  ' "$STATIONS_CONF"
}

# ─── mpv IPC read helper (for now-playing metadata) ────────────────
# Sends a get_property_string request, reads one line of response,
# extracts the "data" field. -T 0.3 caps the round-trip so a flaky mpv
# can never block the status-bar render.
_mpv_get() {
  local sock="$1" prop="$2" raw value
  [ -S "$sock" ] || return 0
  raw="$(printf '{"command":["get_property_string","%s"]}\n' "$prop" \
         | socat -T 0.3 - "UNIX-CONNECT:${sock}" 2>/dev/null \
         | grep -m1 '"data"' || true)"
  [ -n "$raw" ] || return 0
  if command -v jq >/dev/null 2>&1; then
    value="$(printf '%s' "$raw" | jq -r '.data // empty' 2>/dev/null)"
  else
    value="$(printf '%s' "$raw" | sed -n 's/.*"data":"\([^"]*\)".*/\1/p')"
  fi
  [ "$value" = "null" ] && value=""
  printf '%s' "$value"
}

# Best-effort "what's playing right now" — ICY title for streams,
# falling back to media-title (which is usually the URL for streams),
# falling back to whatever mpv exposes as the file path stem.
_now_playing() {
  local sock="$1" t
  for prop in metadata/by-key/icy-title media-title filename; do
    t="$(_mpv_get "$sock" "$prop")"
    if [ -n "$t" ] && [ "$t" != "null" ]; then
      printf '%s' "$t"
      return 0
    fi
  done
}

# Scrolling marquee: pads with a separator so the loop wraps cleanly,
# advances one char per call. Position is window-scoped so each tab
# scrolls its track independently and switching tabs doesn't reset the
# scroll of the tab you came from.
_marquee() {
  local target="$1" text="$2" width="${3:-26}" pos pad len doubled
  [ -n "$text" ] || text="—"
  pad="$text   ✦   "
  len=${#pad}
  if [ "$len" -le "$width" ]; then
    printf '%-*s' "$width" "$text"
    return 0
  fi
  pos="$(tmux_get_win "$target" "@vibe-marquee-pos")"
  pos="${pos:-0}"
  pos=$(( (pos + 1) % len ))
  tmux_set_win "$target" "@vibe-marquee-pos" "$pos"
  doubled="${pad}${pad}"
  printf '%s' "${doubled:$pos:$width}"
}

_intensity_tier() {
  awk -v i="${1:-0}" 'BEGIN{
    if (i+0 < 0.3)      print "chill"
    else if (i+0 < 0.6) print "mellow"
    else                print "intense"
  }'
}

# ─── mpv lifecycle (start / stop) ────────────────────────────────────
_spawn_mpv() {
  local sock="$1"
  # `setsid` would put mpv in its own session and detach from controlling
  # tty, which is what we want; but it doesn't exist on macOS. Settle for
  # nohup + redirect, which is portable.
  nohup mpv --idle=yes --no-terminal --no-video --no-config \
            --really-quiet --keep-open=no \
            --input-ipc-server="$sock" --volume=0 \
       </dev/null >/dev/null 2>>"$VBOX_LOG" &
  echo $!
}

_wait_for_socket() {
  local sock="$1" tries="${2:-30}"
  while [ "$tries" -gt 0 ]; do
    [ -S "$sock" ] && return 0
    sleep 0.1
    tries=$((tries - 1))
  done
  return 1
}

cmd_start() {
  if ! command -v mpv >/dev/null 2>&1 || ! command -v socat >/dev/null 2>&1; then
    log "start: mpv/socat not installed; skipping"
    return 0
  fi
  local target="${1:-}" sess
  sess="$(_session_of "$target")"
  [ -n "$sess" ] || { log "start: no tmux session ($target)"; return 1; }

  # Sweep mpv pairs from sessions tmux no longer has — this catches the
  # case where a previous session ended without firing our cleanup (e.g.,
  # session was created with older code that didn't write state files).
  _reap_dead_sessions

  # already running for this session? bail out.
  local existing_a existing_b
  existing_a="$(tmux_get "$sess" "@vibe-mpv-a-pid")"
  existing_b="$(tmux_get "$sess" "@vibe-mpv-b-pid")"
  if [ -n "$existing_a" ] && kill -0 "$existing_a" 2>/dev/null \
     && [ -n "$existing_b" ] && kill -0 "$existing_b" 2>/dev/null; then
    log "start: already running (pids $existing_a, $existing_b)"
    return 0
  fi
  cmd_stop  # clear any stale state

  local sess_clean sock_dir sock_a sock_b pid_a pid_b
  sess_clean="${sess#\$}"
  sock_dir="${VBOX_RUNTIME_DIR}/sess-${sess_clean}"
  mkdir -p "$sock_dir"
  sock_a="${sock_dir}/a.sock"
  sock_b="${sock_dir}/b.sock"
  rm -f "$sock_a" "$sock_b"

  pid_a="$(_spawn_mpv "$sock_a")"
  pid_b="$(_spawn_mpv "$sock_b")"

  if ! _wait_for_socket "$sock_a" || ! _wait_for_socket "$sock_b"; then
    log "start: mpv slot failed to open socket"
    kill "$pid_a" "$pid_b" 2>/dev/null || true
    return 1
  fi

  tmux_set "$sess" "@vibe-mpv-a-sock" "$sock_a"
  tmux_set "$sess" "@vibe-mpv-b-sock" "$sock_b"
  tmux_set "$sess" "@vibe-mpv-a-pid"  "$pid_a"
  tmux_set "$sess" "@vibe-mpv-b-pid"  "$pid_b"
  tmux_set "$sess" "@vibe-active-slot" "A"
  tmux_set "$sess" "@vibe-muted" "0"

  # Stamp creation time on every window in this session that doesn't
  # already have one — covers the initial window of a brand-new session
  # (after-new-session may not fire reliably on older tmux) and any
  # windows that pre-date the upgrade on a long-lived tmux server.
  local now_ts win
  now_ts="$(date +%s)"
  while read -r win; do
    [ -n "$win" ] || continue
    [ -z "$(tmux_get_win "$win" "@vibe-window-created")" ] || continue
    tmux_set_win "$win" "@vibe-window-created" "$now_ts"
  done < <(tmux list-windows -t "$sess" -F '#{window_id}' 2>/dev/null)

  # Bootstrap @vibe-current-pane to the active pane of the new session.
  # Without this, no focus event has fired yet, _refresh_pane_intensity's
  # `current_pane == pane` check fails, and the first manual mood change
  # (or pane state transition) never triggers a crossfade.
  local initial_pane
  initial_pane="$(tmux display-message -p -t "$sess" '#{pane_id}' 2>/dev/null)"
  [ -n "$initial_pane" ] && tmux_set "$sess" "@vibe-current-pane" "$initial_pane"

  # Status-right inherits the main config's status-interval (1s) — that
  # gives the song marquee a smoother 1-char-per-second scroll and the
  # uptime/clock fresh-each-second feel. Load sampling at 1s is fine for
  # vbox-music tick (it's a few ms of work).

  # Kick off the chill station on slot A immediately. Skipping the
  # crossfade (nothing to fade from) means attach feels musical, not silent.
  local default_url
  default_url="$(_intensity_to_station "0.0" | awk -F '\t' '{print $1}')"
  if [ -n "$default_url" ]; then
    "$IPC_HELPER" "$sock_a" set_property volume 100
    "$IPC_HELPER" "$sock_a" loadfile "$default_url" replace
  fi

  # Begin paused if no client is attached yet (vbox CLI calls start before
  # attach). The subsequent client-attached hook unpauses us.
  cmd_sync_attached

  # Stash cleanup state in a flat file keyed by session id. Tmux's
  # session-scoped options and per-session hooks both vanish when the
  # session is destroyed, so they can't drive cleanup at session-closed
  # time. The global session-closed hook in tmux-vibe.conf reads this file.
  local state_file="${VBOX_RUNTIME_DIR}/sess-${sess_clean}.state"
  {
    printf 'PID_A=%s\n'    "$pid_a"
    printf 'PID_B=%s\n'    "$pid_b"
    printf 'SOCK_DIR=%s\n' "$sock_dir"
  } > "$state_file"

  log "start: spawned mpv pair (A=$pid_a B=$pid_b) for session $sess"
}

cmd_stop() {
  local target="${1:-}" sess
  sess="$(_session_of "$target")"
  [ -n "$sess" ] || return 0
  local slot pid sock sess_clean
  for slot in a b; do
    pid="$(tmux_get  "$sess" "@vibe-mpv-${slot}-pid")"
    sock="$(tmux_get "$sess" "@vibe-mpv-${slot}-sock")"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      sleep 0.1
      kill -9 "$pid" 2>/dev/null || true
    fi
    [ -n "$sock" ] && rm -f "$sock"
    tmux_unset "$sess" "@vibe-mpv-${slot}-pid"
    tmux_unset "$sess" "@vibe-mpv-${slot}-sock"
  done
  tmux_unset "$sess" "@vibe-active-slot"
  tmux_unset "$sess" "@vibe-current-pane"
  tmux_unset "$sess" "@vibe-muted"
  # remove stashed cleanup state
  sess_clean="${sess#\$}"
  rm -f "${VBOX_RUNTIME_DIR}/sess-${sess_clean}.state"
  log "stop: torn down mpv slots for session $sess"
}

# Called by the global session-closed hook with the dying session's id.
# State-file path is the primary signal; the socket-dir pkill is a
# belt-and-suspenders that catches mpv processes from older runs that
# pre-date the state-file design (no state to read but still reachable
# through their --input-ipc-server path).
cmd_cleanup_session() {
  local sess="${1:-}"
  [ -n "$sess" ] || return 0
  local sess_clean state_file sock_dir pid
  sess_clean="${sess#\$}"
  state_file="${VBOX_RUNTIME_DIR}/sess-${sess_clean}.state"
  sock_dir="${VBOX_RUNTIME_DIR}/sess-${sess_clean}"

  # primary path: read the state file written by cmd_start
  if [ -f "$state_file" ]; then
    # shellcheck disable=SC1090  # dynamic path is intentional
    . "$state_file"
    for pid in "${PID_A:-}" "${PID_B:-}"; do
      [ -n "$pid" ] || continue
      if kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null || true
        sleep 0.1
        kill -9 "$pid" 2>/dev/null || true
      fi
    done
    rm -f "$state_file"
    log "cleanup-session: state-file reap for $sess (pids=${PID_A:-} ${PID_B:-})"
  fi

  # fallback: any mpv whose --input-ipc-server points into this sock_dir
  if [ -d "$sock_dir" ]; then
    pkill -f "input-ipc-server=${sock_dir}/" 2>/dev/null || true
    rm -rf "$sock_dir" 2>/dev/null
    log "cleanup-session: pkill-by-socket reap for $sess ($sock_dir)"
  fi
}

# Sweep state files for sessions tmux no longer knows about. Cheap to call
# from cmd_start so each new vibe session also self-heals any orphans the
# previous run leaked.
_reap_dead_sessions() {
  local sf sf_sess
  for sf in "$VBOX_RUNTIME_DIR"/sess-*.state; do
    [ -e "$sf" ] || continue
    sf_sess="${sf##*/sess-}"; sf_sess="${sf_sess%.state}"
    # tmux session ids look like $0, $1, ... — prefix with $ for the lookup
    if ! tmux has-session -t "\$${sf_sess}" 2>/dev/null; then
      cmd_cleanup_session "\$${sf_sess}"
    fi
  done
}

# ─── crossfade ───────────────────────────────────────────────────────
# Equal-power curve: out=cos(t·π/2), in=sin(t·π/2). 30 steps × 100ms ≈ 3s.
# A `mkdir` lock gives us atomic "no-op on overlap" without depending on
# flock (not present on macOS by default).
cmd_crossfade() {
  local target_url="${1:-}" target="${2:-}"
  [ -n "$target_url" ] || { log "crossfade: no url"; return 0; }

  local sess
  sess="$(_session_of "$target")"
  if [ -z "$sess" ]; then
    log "crossfade: no session resolved (target=${target:-<none>})"
    return 0
  fi
  local active_slot
  active_slot="$(tmux_get "$sess" "@vibe-active-slot")"
  [ -n "$active_slot" ] || { log "crossfade: no active slot for $sess"; return 0; }

  local muted
  muted="$(tmux_get "$sess" "@vibe-muted")"

  # atomic lock — overlapping crossfades no-op rather than queue
  local tpid
  tpid="$(_tmux_pid)"
  : "${tpid:=$$}"  # fallback so we still get a unique-enough lock path
  local lock_dir="/tmp/vbox-crossfade-${tpid}.lock"
  if ! mkdir "$lock_dir" 2>/dev/null; then
    log "crossfade: skipped (lock held at $lock_dir)"
    return 0
  fi
  trap 'rmdir "$lock_dir" 2>/dev/null; trap - EXIT' EXIT

  local from_slot to_slot from_sock to_sock
  if [ "$active_slot" = "A" ]; then
    from_slot=A; to_slot=B
  else
    from_slot=B; to_slot=A
  fi
  from_sock="$(tmux_get "$sess" "@vibe-mpv-$(echo "$from_slot" | tr 'A-Z' 'a-z')-sock")"
  to_sock="$(tmux_get   "$sess" "@vibe-mpv-$(echo "$to_slot"   | tr 'A-Z' 'a-z')-sock")"

  if [ -z "$from_sock" ] || [ -z "$to_sock" ]; then
    log "crossfade: missing sockets (from=$from_sock to=$to_sock)"
    rmdir "$lock_dir" 2>/dev/null
    trap - EXIT
    return 0
  fi
  log "crossfade: BEGIN $from_slot→$to_slot url=$target_url sess=$sess"

  # CRITICAL: mpv's `pause` property is sticky across files. If anything
  # paused this slot earlier (sync-attached on detach, an old crossfade,
  # whatever), loadfile loads in paused state and the new audio is
  # silent forever — even though volumes happily ramp up. Force both
  # slots to playing state up front.
  "$IPC_HELPER" "$from_sock" set_property pause no
  "$IPC_HELPER" "$to_sock"   set_property pause no

  # load target on the inactive slot at zero volume
  "$IPC_HELPER" "$to_sock" set_property volume 0
  "$IPC_HELPER" "$to_sock" loadfile "$target_url" replace
  # belt-and-suspenders: re-assert pause=no AFTER loadfile, since some
  # mpv versions reset pause when starting a new file
  "$IPC_HELPER" "$to_sock" set_property pause no

  # if muted, just swap silently — no audible fade
  if [ "$muted" = "1" ]; then
    "$IPC_HELPER" "$from_sock" stop
    tmux_set "$sess" "@vibe-active-slot" "$to_slot"
    log "crossfade: silent swap → $target_url (muted)"
    rmdir "$lock_dir" 2>/dev/null
    trap - EXIT
    return 0
  fi

  local steps=30 i out_v in_v
  for ((i = 1; i <= steps; i++)); do
    # equal-power curve, computed in awk because bash has no trig
    read -r out_v in_v <<<"$(awk -v t="$i" -v n="$steps" 'BEGIN{
      pi=3.141592653589793
      a = (t/n) * (pi/2)
      printf "%.2f %.2f", cos(a)*100, sin(a)*100
    }')"
    "$IPC_HELPER" "$from_sock" set_property volume "$out_v"
    "$IPC_HELPER" "$to_sock"   set_property volume "$in_v"
    sleep 0.1
  done

  # snap to final state in case any step was lost
  "$IPC_HELPER" "$from_sock" set_property volume 0
  "$IPC_HELPER" "$to_sock"   set_property volume 100
  # silence the now-inactive slot — pause first (so even if `stop` is
  # ignored, no audio gets out), then stop to free the network read
  "$IPC_HELPER" "$from_sock" set_property pause yes
  "$IPC_HELPER" "$from_sock" stop

  tmux_set "$sess" "@vibe-active-slot" "$to_slot"
  log "crossfade: END $from_slot→$to_slot $target_url"

  rmdir "$lock_dir" 2>/dev/null
  trap - EXIT
}

# ─── per-pane intensity refresh ──────────────────────────────────────
# Re-derives intensity from state + load, applies any active manual bump,
# updates @vibe-station, and triggers a crossfade if the focused pane's
# station just changed.
# Map a tier name to a representative intensity in the middle of that
# range (used by the manual mood override).
_tier_to_intensity() {
  case "${1:-}" in
    chill)   echo "0.150" ;;
    mellow)  echo "0.450" ;;
    intense) echo "0.850" ;;
    *)       echo "" ;;
  esac
}

_refresh_pane_intensity() {
  local pane="$1"
  [ -n "$pane" ] || return 0

  local sess override forced_intensity
  sess="$(_session_of "$pane")"
  # mood is now per-window: each tab carries its own override
  override="$(tmux_get_win "$pane" "@vibe-mood-override")"
  forced_intensity="$(_tier_to_intensity "$override")"

  local state intensity
  state="$(tmux_get_pane "$pane" "@vibe-state")"
  state="${state:-idle}"

  # expire stale manual bumps
  local bump_until bump_offset now
  bump_until="$(tmux_get_pane "$pane" "@vibe-bump-until")"
  bump_offset="$(tmux_get_pane "$pane" "@vibe-bump-offset")"
  now="$(date +%s)"
  if [ -n "$bump_until" ] && [ "$now" -ge "$bump_until" ]; then
    tmux_unset_pane "$pane" "@vibe-bump-until"
    tmux_unset_pane "$pane" "@vibe-bump-offset"
    bump_offset=""
  fi

  if [ -n "$forced_intensity" ]; then
    # manual mood override wins over auto computation + bumps
    intensity="$forced_intensity"
  elif [ "$state" = "idle" ]; then
    intensity="0.000"
  else
    local pane_pid cpu_share mem_share
    pane_pid="$(tmux display-message -p -t "$pane" '#{pane_pid}' 2>/dev/null)"
    read -r cpu_share mem_share <<<"$(_vbox_pane_load "$pane_pid")"
    intensity="$(awk -v c="${cpu_share:-0}" -v m="${mem_share:-0}" 'BEGIN{
      x = 0.2 + c + 0.5*m
      if (x<0) x=0; if (x>1) x=1
      printf "%.3f", x
    }')"
  fi

  if [ -z "$forced_intensity" ] && [ -n "$bump_offset" ]; then
    intensity="$(awk -v i="$intensity" -v o="$bump_offset" 'BEGIN{
      x = i + o
      if (x<0) x=0; if (x>1) x=1
      printf "%.3f", x
    }')"
  fi

  tmux_set_pane "$pane" "@vibe-intensity" "$intensity"

  local url label prev_url
  IFS=$'\t' read -r url label <<<"$(_intensity_to_station "$intensity")"
  [ -z "$url" ] && return 0
  prev_url="$(tmux_get_pane "$pane" "@vibe-station")"
  tmux_set_pane "$pane" "@vibe-station" "$url"
  tmux_set_pane "$pane" "@vibe-station-label" "${label:-}"

  # if this is the currently-focused pane and the station shifted, crossfade
  local current_pane
  current_pane="$(tmux_get "$sess" "@vibe-current-pane")"
  if [ "$current_pane" = "$pane" ] && [ "$url" != "$prev_url" ]; then
    cmd_crossfade "$url" "$pane" >/dev/null 2>&1 &
  fi
}

# ─── dispatchers called from hooks ───────────────────────────────────
cmd_focus() {
  local pane="${1:-}"
  [ -n "$pane" ] || return 0
  local sess active_slot
  sess="$(_session_of "$pane")"
  [ -n "$sess" ] || return 0
  active_slot="$(tmux_get "$sess" "@vibe-active-slot")"
  [ -n "$active_slot" ] || return 0  # vibe not active for this session

  tmux_set "$sess" "@vibe-current-pane" "$pane"
  _refresh_pane_intensity "$pane"

  local url
  url="$(tmux_get_pane "$pane" "@vibe-station")"
  [ -n "$url" ] || return 0
  cmd_crossfade "$url" "$pane"
}

cmd_set_state() {
  local pane="${1:-}" state="${2:-}"
  [ -n "$pane" ] && [ -n "$state" ] || return 0
  case "$state" in idle|running|thinking) ;; *) return 0 ;; esac
  # short-circuit on non-vibe sessions so we don't pollute their options
  local sess active_slot
  sess="$(_session_of "$pane")"
  [ -n "$sess" ] || return 0
  active_slot="$(tmux_get "$sess" "@vibe-active-slot")"
  [ -n "$active_slot" ] || return 0
  tmux_set_pane "$pane" "@vibe-state" "$state"
  _refresh_pane_intensity "$pane"
}

cmd_tick() {
  local sess active_slot
  sess="$(_session_of)" || return 0
  [ -n "$sess" ] || return 0
  active_slot="$(tmux_get "$sess" "@vibe-active-slot")"
  [ -n "$active_slot" ] || return 0  # render nothing in non-vibe sessions

  local muted
  muted="$(tmux_get "$sess" "@vibe-muted")"
  if [ "$muted" = "1" ]; then
    printf '🔇 muted'
    return 0
  fi

  # network-unreachable / mpv-died sentinel: if the active slot's pid is gone,
  # render the offline indicator instead of pretending to play
  local active_slot_lc active_pid active_sock
  active_slot_lc="$(echo "$active_slot" | tr 'A-Z' 'a-z')"
  active_pid="$(tmux_get  "$sess" "@vibe-mpv-${active_slot_lc}-pid")"
  active_sock="$(tmux_get "$sess" "@vibe-mpv-${active_slot_lc}-sock")"
  if [ -n "$active_pid" ] && ! kill -0 "$active_pid" 2>/dev/null; then
    printf '📻 off-air'
    return 0
  fi

  local pane
  pane="$(tmux_get "$sess" "@vibe-current-pane")"
  [ -n "$pane" ] || pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null)"
  _refresh_pane_intensity "$pane"

  local intensity tier override emoji_label
  intensity="$(tmux_get_pane "$pane" "@vibe-intensity")"
  intensity="${intensity:-0}"
  tier="$(_intensity_tier "$intensity")"
  override="$(tmux_get_win "$pane" "@vibe-mood-override")"
  case "$tier" in
    intense) emoji_label='🔥 cooking'  ;;
    mellow)  emoji_label='🎷 grooving' ;;
    *)       emoji_label='🌿 cruising' ;;
  esac
  # a small lock icon when the user pinned the mood manually, so the
  # status reflects "this is my choice, not the auto-picker"
  [ -n "$override" ] && emoji_label="${emoji_label} 🔒"

  local station song marquee out
  station="$(tmux_get_pane "$pane" "@vibe-station-label")"
  song="$(_now_playing "$active_sock")"
  # marquee position is per-window so each tab keeps its own scroll
  marquee="$(_marquee "$pane" "$song" 26)"

  if [ -n "$station" ]; then
    out="${emoji_label} · ${station} ♫ ${marquee}"
  else
    out="${emoji_label} ♫ ${marquee}"
  fi
  printf '%s' "$out"
}

cmd_sync_attached() {
  # Walk every vibe-enabled session and pause the active slot when it has
  # zero attached clients, unpause it when at least one is back. Called
  # from client-attached / client-detached / client-session-changed hooks
  # so mpv stops streaming the moment you detach.
  local sess attached active_slot active_sock pause_val
  while IFS='|' read -r sess attached; do
    [ -n "$sess" ] || continue
    active_slot="$(tmux_get "$sess" "@vibe-active-slot")"
    [ -n "$active_slot" ] || continue
    active_sock="$(tmux_get "$sess" "@vibe-mpv-$(echo "$active_slot" | tr 'A-Z' 'a-z')-sock")"
    [ -n "$active_sock" ] || continue
    if [ "${attached:-0}" -gt 0 ]; then
      pause_val="no"
    else
      pause_val="yes"
    fi
    "$IPC_HELPER" "$active_sock" set_property pause "$pause_val"
  done < <(tmux list-sessions -F '#{session_id}|#{session_attached}' 2>/dev/null)
}

cmd_mute() {
  local pane_arg="${1:-}" sess muted pane
  if [ -n "$pane_arg" ]; then
    pane="$pane_arg"
  else
    pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null)"
  fi
  sess="$(_session_of "$pane")"
  [ -n "$sess" ] || return 0
  muted="$(tmux_get "$sess" "@vibe-muted")"
  local active_slot active_sock
  active_slot="$(tmux_get "$sess" "@vibe-active-slot")"
  [ -n "$active_slot" ] || return 0
  active_sock="$(tmux_get "$sess" "@vibe-mpv-$(echo "$active_slot" | tr 'A-Z' 'a-z')-sock")"

  if [ "$muted" = "1" ]; then
    tmux_set "$sess" "@vibe-muted" "0"
    # fade back up
    local i
    for ((i = 1; i <= 15; i++)); do
      "$IPC_HELPER" "$active_sock" set_property volume "$(awk -v i="$i" 'BEGIN{printf "%.2f", i*100/15}')"
      sleep 0.05
    done
    "$IPC_HELPER" "$active_sock" set_property volume 100
  else
    tmux_set "$sess" "@vibe-muted" "1"
    local i
    for ((i = 14; i >= 0; i--)); do
      "$IPC_HELPER" "$active_sock" set_property volume "$(awk -v i="$i" 'BEGIN{printf "%.2f", i*100/15}')"
      sleep 0.05
    done
    "$IPC_HELPER" "$active_sock" set_property volume 0
  fi
}

cmd_bump() {
  local delta="${1:-0}"
  local sess pane bump_until bump_offset now
  pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null)"
  [ -n "$pane" ] || return 0
  sess="$(_session_of "$pane")"
  [ -n "$sess" ] || return 0
  now="$(date +%s)"
  bump_offset="$(tmux_get_pane "$pane" "@vibe-bump-offset")"
  bump_offset="$(awk -v cur="${bump_offset:-0}" -v d="$delta" 'BEGIN{
    x = cur + d
    if (x < -0.5) x = -0.5
    if (x >  0.5) x =  0.5
    printf "%.2f", x
  }')"
  bump_until=$((now + 60))
  tmux_set_pane "$pane" "@vibe-bump-offset" "$bump_offset"
  tmux_set_pane "$pane" "@vibe-bump-until"  "$bump_until"
  _refresh_pane_intensity "$pane"
}

# Manual mood — sticky window-scoped override of the auto-derived tier.
# Each tab carries its own mood; switching tabs swaps in that tab's mood.
# Args: chill | mellow | intense | auto | next | prev
cmd_mood() {
  local arg="${1:-next}" pane_arg="${2:-}" sess pane cur next
  # Prefer the pane id passed by the keybinding (`#{pane_id}` substituted
  # at hook fire time, before forking) — it's authoritative. Fall back to
  # display-message only if the caller didn't pass one (e.g., manual CLI
  # invocation from inside a vibe pane).
  if [ -n "$pane_arg" ]; then
    pane="$pane_arg"
  else
    pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null)"
  fi
  [ -n "$pane" ] || { log "mood: no pane resolved"; return 0; }
  sess="$(_session_of "$pane")"
  [ -n "$sess" ] || { log "mood: no session for pane $pane"; return 0; }
  log "mood: arg=$arg pane=$pane sess=$sess"

  cur="$(tmux_get_win "$pane" "@vibe-mood-override")"

  case "$arg" in
    auto|off|"")
      tmux_unset_win "$pane" "@vibe-mood-override"
      ;;
    chill|mellow|intense)
      tmux_set_win "$pane" "@vibe-mood-override" "$arg"
      ;;
    next)
      case "${cur:-auto}" in
        auto|"") next="chill" ;;
        chill)   next="mellow" ;;
        mellow)  next="intense" ;;
        intense) next="auto" ;;
      esac
      if [ "$next" = "auto" ]; then
        tmux_unset_win "$pane" "@vibe-mood-override"
      else
        tmux_set_win "$pane" "@vibe-mood-override" "$next"
      fi
      ;;
    prev)
      case "${cur:-auto}" in
        auto|"") next="intense" ;;
        intense) next="mellow" ;;
        mellow)  next="chill" ;;
        chill)   next="auto" ;;
      esac
      if [ "$next" = "auto" ]; then
        tmux_unset_win "$pane" "@vibe-mood-override"
      else
        tmux_set_win "$pane" "@vibe-mood-override" "$next"
      fi
      ;;
    *)
      log "mood: unknown arg '$arg' (want chill|mellow|intense|auto|next|prev)"
      return 1
      ;;
  esac
  _refresh_pane_intensity "$pane"
  # Force a crossfade unconditionally — the user just pressed a mood key
  # and expects to hear the change, even if the new tier maps to the same
  # station as before (which happens when going auto→chill on an idle pane).
  local url
  url="$(tmux_get_pane "$pane" "@vibe-station")"
  [ -n "$url" ] && cmd_crossfade "$url" "$pane" >/dev/null 2>&1 &
}

# Diagnostic dump — paste this output when reporting issues. Shows the
# session/window/pane state, the mpv processes vbox-music thinks it owns,
# and a probe of each socket's IPC roundtrip.
cmd_diag() {
  local pane sess
  pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null)"
  sess="$(_session_of "$pane")"
  echo "── vbox-music diag ─────────────────────────────"
  echo "tmux:    $(tmux -V 2>/dev/null)"
  echo "pane:    $pane"
  echo "sess:    $sess"
  if [ -n "$sess" ]; then
    echo ""
    echo "session options:"
    for opt in "@vibe-active-slot" "@vibe-current-pane" "@vibe-muted" \
               "@vibe-mpv-a-sock" "@vibe-mpv-b-sock" \
               "@vibe-mpv-a-pid" "@vibe-mpv-b-pid"; do
      printf "  %-22s = %s\n" "$opt" "$(tmux_get "$sess" "$opt")"
    done
    echo ""
    echo "window options (current pane's window):"
    for opt in "@vibe-window-created" "@vibe-mood-override" "@vibe-marquee-pos"; do
      printf "  %-22s = %s\n" "$opt" "$(tmux_get_win "$pane" "$opt")"
    done
    echo ""
    echo "pane options (current pane):"
    for opt in "@vibe-state" "@vibe-intensity" "@vibe-station" "@vibe-station-label"; do
      printf "  %-22s = %s\n" "$opt" "$(tmux_get_pane "$pane" "$opt")"
    done
  fi
  echo ""
  echo "mpv processes (whole system):"
  pgrep -af 'mpv.*input-ipc-server' || echo "  (none)"
  echo ""
  echo "ipc probe — mpv pause + filename for each slot:"
  for slot in a b; do
    local sock pause_v file_v
    sock="$(tmux_get "$sess" "@vibe-mpv-${slot}-sock")"
    if [ -z "$sock" ] || [ ! -S "$sock" ]; then
      echo "  $slot: socket missing ($sock)"
      continue
    fi
    pause_v="$(_mpv_get "$sock" "pause")"
    file_v="$(_mpv_get  "$sock" "filename")"
    echo "  $slot ($sock): pause=$pause_v file=$file_v"
  done
  echo ""
  echo "music.log tail:"
  tail -n 20 "$VBOX_LOG" 2>/dev/null | sed 's/^/  /' || echo "  (no log)"
  echo "─────────────────────────────────────────────────"
}

# ─── main ────────────────────────────────────────────────────────────
usage() {
  cat <<'USAGE'
Usage: vbox-music <command> [args...]

  start [target]        spawn mpv slot pair for the given (or current) session
  stop  [target]        kill mpv slot pair for the given (or current) session
  sync-attached         pause/unpause active slot per session_attached count
  reap                  reap mpv pairs from sessions tmux no longer has
  crossfade <url>       crossfade active slot → inactive slot playing <url>
  focus <pane_id>       called by tmux pane-focus-in hook
  set-state <p> <s>     s ∈ {idle,running,thinking}
  tick                  status-bar render: emoji + station + scrolling song
  mute                  toggle global mute
  bump <delta>          shift intensity by <delta> for 60s (e.g. +0.25)
  mood <m>              m ∈ {chill,mellow,intense,auto,next,prev} (sticky)
USAGE
}

cmd="${1:-}"
shift || true
case "$cmd" in
  start)            cmd_start "$@" ;;
  stop|kill)        cmd_stop  "$@" ;;
  crossfade)        cmd_crossfade "$@" ;;
  focus)            cmd_focus "$@" ;;
  set-state)        cmd_set_state "$@" ;;
  tick)             cmd_tick  "$@" ;;
  mute)             cmd_mute  "$@" ;;
  bump)             cmd_bump  "$@" ;;
  mood)             cmd_mood  "$@" ;;
  sync-attached)    cmd_sync_attached "$@" ;;
  cleanup-session)  cmd_cleanup_session "$@" ;;
  reap)             _reap_dead_sessions ;;
  diag)             cmd_diag "$@" ;;
  -h|--help|help|"") usage ;;
  *) usage; exit 1 ;;
esac
